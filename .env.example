# Copy this file to .env and fill in the values.
# .env is gitignored; do not commit real secrets.

# --- Android release signing (read by android/app/build.gradle.kts) ---
AIRTYPE_KEYSTORE_PATH=C:/path/to/airtype.jks
AIRTYPE_KEYSTORE_PASSWORD=keystorepassword
AIRTYPE_KEY_ALIAS=airtype
AIRTYPE_KEY_PASSWORD=keypassword

# --- Website deploy target (read by publish.bat) ---
DEPLOY_DIR=C:/path/to/website/public/downloads/airtype
